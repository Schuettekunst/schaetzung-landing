---
// Sektion 3: Erzielte Ergebnisse – social proof durch konkrete Auktionszuschläge
// Mobile: horizontales Scroll-Karussell mit scroll-snap (kein JS-Lib)
// Tablet+: 2-Spalten-Grid
// Desktop: 3-Spalten-Grid
const results = [
  { artist: 'Wolfgang Mattheuer (Gemälde)', price: '100.000 €', file: 'mattheuer-gemaelde.jpg' },
  { artist: 'Neo Rauch',                    price: '93.947 €',  file: 'neo-rauch.jpg' },
  { artist: 'Michael Triegel',              price: '85.800 €',  file: 'triegel.jpg' },
  { artist: 'Henri Rousseau',               price: '75.000 €',  file: 'henri-rousseau.jpg' },
  { artist: 'Jiri Georg Dokoupil',          price: '59.400 €',  file: 'dokoupil.jpg' },
  { artist: 'Karl Schmidt-Rottluff',        price: '33.595 €',  file: 'schmidt-rottluff.jpg' },
  { artist: 'Jean Lambert-Rucki',           price: '32.683 €',  file: 'lambert-rucki.jpg' },
  { artist: 'Otto Müller',                  price: '25.080 €',  file: 'otto-mueller.jpg' },
  { artist: 'Georg Kolbe',                  price: '21.120 €',  file: 'georg-kolbe.jpg' },
];
---

<section id="ergebnisse" class="bg-cream">
  <div class="container-content py-20 lg:py-28">
    <div class="max-w-2xl">
      <span class="eyebrow">Aktuelle Auktionsergebnisse</span>
      <h2 class="section-title">Rekordzuschläge aus unseren Auktionen</h2>
      <p class="section-sub">
        Eine Auswahl aktueller Ergebnisse aus unseren Auktionen. Klassische Moderne,
        Leipziger Schule, zeitgenössische Kunst – wir erzielen regelmäßig fünf- und
        sechsstellige Ergebnisse für unsere Einlieferer.
      </p>
    </div>

    <div class="hairline mt-12 mb-12"></div>

    <ul
      id="resultsCarousel"
      class="results-track flex md:grid overflow-x-auto md:overflow-visible snap-x snap-mandatory md:snap-none md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-x-8 md:gap-y-14 -mx-5 sm:-mx-6 md:mx-0 px-5 sm:px-6 md:px-0 pb-4 md:pb-0 scroll-smooth"
    >
      {results.map((r) => (
        <li class="results-card snap-start shrink-0 w-[80vw] md:w-auto group">
          <figure>
            <div class="relative aspect-[4/5] bg-white border border-border overflow-hidden">
              <img
                src={`/images/results/${r.file}`}
                alt={`Werk von ${r.artist}, versteigert über Schütte Kunstauktionen`}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                loading="lazy"
                decoding="async"
                width="600"
                height="750"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
              />
              <div
                class="absolute inset-0 hidden flex-col items-center justify-center text-center p-6 bg-gradient-to-br from-primary-50 to-cream"
                aria-hidden="true"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mb-3 text-accent/70" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 19.5h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z"/>
                </svg>
                <span class="font-serif text-primary/70 text-base">{r.artist}</span>
                <code class="text-[10px] text-muted mt-2">{r.file}</code>
              </div>
            </div>
            <figcaption class="mt-5">
              <h3 class="font-serif text-primary text-xl leading-tight">{r.artist}</h3>
              <p class="mt-2 text-sm text-muted">
                Ergebnis: <span class="text-accent font-medium tracking-wide">{r.price}</span>
              </p>
            </figcaption>
          </figure>
        </li>
      ))}
    </ul>

    <!-- Karussell-UI: nur Mobile -->
    <div class="md:hidden mt-6 flex flex-col items-center gap-3">
      <div
        id="resultsDots"
        class="flex items-center gap-2"
        role="tablist"
        aria-label="Werk auswählen"
      >
        {results.map((r, i) => (
          <button
            type="button"
            class="results-dot h-1.5 w-1.5 rounded-full bg-primary/25 transition-all duration-300 cursor-pointer"
            data-index={i}
            aria-label={`Zu Werk ${i + 1}: ${r.artist}`}
          />
        ))}
      </div>
      <p class="text-xs italic text-muted select-none" aria-hidden="true">
        ← swipen für mehr →
      </p>
    </div>

    <p class="mt-16 text-center text-xs text-muted italic">
      Erfolgreich versteigert über Schütte Kunstauktionen. Alle Ergebnisse inkl. Aufgeld.
    </p>
  </div>
</section>

<style>
  /* Native Scrollbar auf Mobile-Karussell ausblenden */
  .results-track {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .results-track::-webkit-scrollbar {
    display: none;
  }

  /* Aktiver Indicator-Punkt: breiter, in Goldakzent */
  .results-dot[data-active] {
    width: 1.5rem;
    background-color: #b8935e;
  }

  /* Reduce motion respektieren */
  @media (prefers-reduced-motion: reduce) {
    .results-track {
      scroll-behavior: auto;
    }
    .results-dot {
      transition: none;
    }
  }
</style>

<script>
  const track = document.getElementById('resultsCarousel');
  const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.results-dot'));
  const cards = track ? Array.from(track.querySelectorAll<HTMLElement>('.results-card')) : [];

  function setActive(idx: number) {
    dots.forEach((d, i) => {
      if (i === idx) d.setAttribute('data-active', '');
      else d.removeAttribute('data-active');
    });
  }

  if (track && dots.length && cards.length) {
    // IntersectionObserver: erkennt, welche Karte im Karussell dominant sichtbar ist
    const observer = new IntersectionObserver(
      (entries) => {
        // Pro Tick die Karte mit höchstem intersectionRatio nehmen
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
        if (visible) {
          const idx = cards.indexOf(visible.target as HTMLElement);
          if (idx >= 0) setActive(idx);
        }
      },
      { root: track, threshold: [0.5, 0.75, 1] }
    );

    cards.forEach((card) => observer.observe(card));
    setActive(0);

    // Click auf Indicator scrollt zur Karte
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        cards[i]?.scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      });
    });
  }
</script>

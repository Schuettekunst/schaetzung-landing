---
// DSGVO-konformer Cookie-Banner mit Google Consent Mode V2
//
// Wichtig: GTM wird IMMER über Base.astro geladen (Consent Mode V2 Pattern).
// Dieser Banner sendet nur gtag('consent','update', ...) — die Tags innerhalb
// von GTM dürfen erst feuern, sobald der User auf "Akzeptieren" geklickt hat.
// "Ablehnen" muss kein gtag-Update senden, weil der Default-State bereits 'denied' ist.
---

<div
  id="cookieBanner"
  class="fixed inset-x-0 bottom-0 z-50 hidden"
  role="dialog"
  aria-modal="false"
  aria-labelledby="cookieBannerTitle"
>
  <div class="mx-auto max-w-content m-4 sm:m-6">
    <div class="bg-primary text-cream shadow-2xl border border-accent/30">
      <div class="p-6 sm:p-8 grid lg:grid-cols-[1fr_auto] gap-6 items-center">
        <div>
          <h2 id="cookieBannerTitle" class="font-serif text-cream text-xl mb-2">
            Cookies & Tracking
          </h2>
          <p class="text-sm text-cream/85 leading-relaxed max-w-2xl">
            Wir verwenden Cookies, um unsere Website zu optimieren und Werbung
            auszuspielen. Mit Klick auf „Akzeptieren" stimmen Sie der Verwendung zu.
            Mehr in unserer
            <a href="/datenschutz" class="underline hover:text-accent">Datenschutzerklärung</a>.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 lg:flex-col xl:flex-row shrink-0">
          <button
            id="cookieAccept"
            type="button"
            class="bg-accent text-white border border-accent px-6 py-3 text-sm uppercase tracking-wider2 font-medium hover:bg-accent-600 transition-colors"
          >
            Akzeptieren
          </button>
          <button
            id="cookieReject"
            type="button"
            class="bg-transparent text-cream border border-cream/30 px-6 py-3 text-sm uppercase tracking-wider2 font-medium hover:border-cream/60 transition-colors"
          >
            Ablehnen
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'cookie-consent-v1';
    var banner = document.getElementById('cookieBanner');
    var acceptBtn = document.getElementById('cookieAccept');
    var rejectBtn = document.getElementById('cookieReject');

    function gtag() {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(arguments);
    }

    function grantAll() {
      gtag('consent', 'update', {
        'ad_storage': 'granted',
        'ad_user_data': 'granted',
        'ad_personalization': 'granted',
        'analytics_storage': 'granted'
      });
    }

    function hideBanner() {
      if (banner) banner.classList.add('hidden');
    }

    function showBanner() {
      if (banner) banner.classList.remove('hidden');
    }

    function accept() {
      try { localStorage.setItem(STORAGE_KEY, 'accepted'); } catch (e) {}
      grantAll();
      hideBanner();
    }

    function reject() {
      try { localStorage.setItem(STORAGE_KEY, 'rejected'); } catch (e) {}
      // Default-State ist bereits 'denied' (siehe Base.astro) — kein gtag-Update nötig.
      hideBanner();
    }

    if (acceptBtn) acceptBtn.addEventListener('click', accept);
    if (rejectBtn) rejectBtn.addEventListener('click', reject);

    var stored = null;
    try { stored = localStorage.getItem(STORAGE_KEY); } catch (e) {}

    if (stored === 'accepted') {
      // User hatte schon zugestimmt — Consent wiederherstellen, Banner bleibt aus
      grantAll();
    } else if (stored === 'rejected') {
      // Bereits abgelehnt — Default-State ('denied') wirkt weiter, Banner bleibt aus
    } else {
      // Keine Entscheidung gespeichert — Banner zeigen
      showBanner();
    }
  })();
</script>
